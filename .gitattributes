*.bat text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
# Frontend text sources: keep LF on every platform so Biome's `lineEnding: lf`
# check passes identically on Windows checkouts, whose default CRLF would
# otherwise report spurious whole-file format diffs.
*.ts text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.svelte text eol=lf
*.css text eol=lf
# SQLite stores migration statement text verbatim in sqlite_master, so the
# schema-identity checks need the .sql sources byte-stable across platforms.
*.sql text eol=lf
# Generated OpenAPI client types: keep LF on every platform so the
# freshness check (`npm run gen:api:check`) compares byte-identical output.
frontend/src/lib/api/schema.d.ts text eol=lf
# Bundled native binaries (the ONNX Runtime + DirectML libraries and the OCR
# model): always binary, never line-ending- or text-normalised.
*.dll binary
*.onnx binary
# The backend/ tree is the retained Python equivalence oracle: a test-only
# reference implementation the cross-language differential checks the shipped
# Rust binary against. It is never shipped (the product is the Rust binary plus
# the Svelte frontend), so it is marked linguist-vendored: the repository
# language statistics then reflect the shipped product rather than the test
# scaffolding. The oracle's code remains fully reviewed (expand the collapsed
# diff); this attribute affects GitHub's display only, not the build or tests.
backend/** linguist-vendored
