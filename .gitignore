# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
pytest-cache-files-*/
.ruff_cache/
.mypy_cache/
# Coverage measurement artefacts (pytest-cov / coverage.py output).
.coverage
.coverage.*
coverage.xml
htmlcov/
# Mutation-testing working tree and stats (mutmut copies the package here and
# records per-mutant results; regenerated by every campaign, never committed).
mutants/
# cargo-mutants equivalent for the Rust workspace (per-campaign output dir,
# written wherever the campaign runs).
mutants.out/
mutants.out.old/
dist/
# PyInstaller working dir (sibling of dist/ at repo root for the backend sidecar build)
/build/

# Node/Frontend
node_modules/
frontend/build/
frontend/.svelte-kit/

# Tauri (the cargo workspace target dir sits at the workspace root; the
# shell-specific artefacts live in the entropia-orme member)
frontend/src-tauri/target/
frontend/src-tauri/entropia-orme/gen/schemas/
# Sidecar binaries: the frozen Python backend lives here at build time
# (renamed from dist/entropiaorme-backend.exe with the platform triple
# Tauri's externalBin requires). Built artefact, not source.
frontend/src-tauri/entropia-orme/binaries/
# Per-checkout Tauri dev config overlay generated by build-dev-config.mjs
# right before `tauri dev` runs, carrying the env-driven devUrl. Tauri 2
# has no native env-var interpolation in tauri.conf.json, so this overlay
# is how Vite's env-driven port stays in lockstep with Tauri's loaded URL.
frontend/src-tauri/entropia-orme/tauri.dev.local.json

# Per-checkout local dev runtime state: Caddy routing fragments for
# additional checkouts (the committed Caddyfile imports
# `.dev/Caddyfile.worktrees/*.caddy` so each additional checkout's hostname
# routes alongside the tracked canonical stanza) plus CoreDNS log files
# captured by `just dns-up`. Never tracked.
.dev/

# Config & secrets
.env
# Local dotenv consumed by `just`'s `set dotenv-load` to drive
# ENTROPIAORME_BACKEND_PORT / ENTROPIAORME_FRONTEND_PORT /
# ENTROPIAORME_DATA_DIR / ENTROPIAORME_HOSTNAME.
# Per-checkout; never tracked.
.env.local
# direnv activation file. Sources .env.local on `cd`-in so direct shell
# invocations honour the env without going through launch scripts.
# Per-checkout; never tracked.
.envrc
config.json
*.db
*.db-journal
*.db-wal
*.db-shm

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Runtime data (SQLite databases and generated files). data/* (not data/) so
# the directory remains walked and per-path re-inclusions work below.
data/*
!backend/data/

# Bundled curated demo DB — committed so PyInstaller datas can include it for
# the v0.1.0 frozen build's guide-mode playback (the /demo/* router reads it
# read-only and clones into in-memory before any tracker priming). Everything
# else under data/demo/ stays ignored (transient SQLite -wal/-shm, settings).
!data/demo/
data/demo/*
!data/demo/entropia_orme.db
!data/demo/seed_manifest.json

# Diagnostic/temp artifacts
tmp/
/calibration/

# Session-recording bundles. The synthetic placeholder is the tracked public
# stand-in; real recorded bundles are local-by-default (kept in a local,
# un-pushed store and copied in when the environment is set up), never pushed
# to the public remote. The in-flight staging dir is never committed.
backend/tests/e2e/corpus/recording_in_progress/
backend/tests/e2e/corpus/recorded/*
!backend/tests/e2e/corpus/recorded/placeholder_recorded_hunt/

# OCR equivalence goldens. They encode a real account's recognised skill levels
# (derived from the local-by-default recorded panels), so they are local-by-
# default too: regenerated locally with --force-regen and never pushed. The
# equivalence test skips when the panels are absent, so the public surface and
# CI stay green without them.
backend/tests/e2e/test_ocr_equivalence/

# Local dev scratch dirs
/.scratch/
/agents/
/.venv-*/
.claude/
