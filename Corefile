# entropiaorme dev-environment DNS resolver.
#
# Answers `*.localhost` queries with 127.0.0.1 (and `::1` for AAAA) so dev
# hostnames resolve through every OS resolver path, including Windows
# Winsock — which doesn't honour RFC 6761's `.localhost` reservation for
# subdomains the way RFC-compliant resolvers (libcurl/c-ares, glibc) do.
# Pairs with the Caddyfile: DNS resolves the hostname to loopback, Caddy
# reverse-proxies the HTTPS request to the right frontend port.
#
# Start with `just dns-up`; `just dns-status` for a liveness check; `just
# dns-down` to stop. Skipping the CoreDNS install keeps the existing
# port-based `just dev` flow unmodified (no hostname resolution needed).
#
# Listens on 127.0.0.1:53 (loopback-only). Non-`.localhost` queries forward
# to public upstream DNS so non-project resolution continues to work with
# this server in the path. Cache caps upstream-DNS load; log/errors give
# operational visibility during dev.

. {
    bind 127.0.0.1
    template IN A localhost {
        match "^(.*\.)?localhost\.$"
        answer "{{ .Name }} 0 IN A 127.0.0.1"
        fallthrough
    }
    template IN AAAA localhost {
        match "^(.*\.)?localhost\.$"
        answer "{{ .Name }} 0 IN AAAA ::1"
        fallthrough
    }
    forward . 1.1.1.1 8.8.8.8 {
        policy sequential
    }
    cache 30
    log
    errors
}
