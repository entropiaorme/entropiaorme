# entropiaorme dev-environment DNS resolver.
#
# Answers `*.localhost` queries with 127.0.0.1 (and `::1` for AAAA). This
# only takes effect for queries that actually reach CoreDNS: a running
# CoreDNS does not by itself make the OS consult it. Windows in particular
# does not send `.localhost` lookups to a configured resolver by default
# (it short-circuits the `.localhost` namespace), so the hostname path
# needs a one-time OS-level step to route that namespace here: see the
# README's "Optional dev environment" section (the NRPT rule). Without it
# the OS returns NXDOMAIN for the dev hostname and `just dev` falls back to
# the port-based URL. Pairs with the Caddyfile: DNS resolves the hostname to
# loopback, Caddy reverse-proxies the HTTPS request to the right frontend
# port.
#
# Start with `just dns-up`; `just dns-status` for a liveness check; `just
# dns-down` to stop. Skipping the CoreDNS install keeps the existing
# port-based `just dev` flow unmodified (no hostname resolution needed).
#
# Listens on 127.0.0.1:53 (loopback-only). Non-`.localhost` queries forward
# to public upstream DNS, so any non-project query that reaches this server
# still resolves. Cache caps upstream-DNS load; log/errors give operational
# visibility during dev.

. {
    bind 127.0.0.1
    template IN A localhost {
        match "^(.*\.)?localhost\.$"
        answer "{{ .Name }} 0 IN A 127.0.0.1"
        fallthrough
    }
    template IN AAAA localhost {
        match "^(.*\.)?localhost\.$"
        answer "{{ .Name }} 0 IN AAAA ::1"
        fallthrough
    }
    forward . 1.1.1.1 8.8.8.8 {
        policy sequential
    }
    cache 30
    log
    errors
}
