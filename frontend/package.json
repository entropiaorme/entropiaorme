{
	"name": "entropia-orme-frontend",
	"private": true,
	"version": "0.1.0",
	"description": "Tauri shell + Svelte frontend for EntropiaOrme, an analytical desktop tool for Entropia Universe.",
	"type": "module",
	"license": "MIT",
	"author": "Mikel Williams-Lekuona <MikelWL@protonmail.com>",
	"engines": {
		"node": ">=20.19.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen:api": "openapi-typescript ../backend/tests/expected/openapi.snapshot.json -o src/lib/api/schema.d.ts --default-non-nullable false",
		"gen:api:check": "npm run gen:api && git diff --exit-code -- src/lib/api/schema.d.ts",
		"tauri": "tauri",
		"tauri:dev": "node src-tauri/build-dev-config.mjs && tauri dev --config src-tauri/tauri.dev.conf.json --config src-tauri/tauri.dev.local.json",
		"tauri:build": "tauri build --bundles nsis",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.9.0",
		"@vitest/coverage-v8": "^3.2.6",
		"happy-dom": "^20.9.0",
		"openapi-typescript": "^7.13.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.6"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@tauri-apps/plugin-store": "^2.4.3",
		"marked": "^15.0.0",
		"motion": "^12.38.0",
		"openapi-fetch": "^0.17.0"
	},
	"overrides": {
		"cookie": "^0.7.0"
	}
}
