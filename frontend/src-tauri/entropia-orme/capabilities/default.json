{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for EntropiaOrme. The `windows` list includes runtime-spawned overlay popups (overlay-menu, overlay-armour-cost) that are created on-demand via WebviewWindow from frontend/src/routes/overlay.",
  "windows": ["main", "overlay", "overlay-menu", "overlay-armour-cost", "scan-overlay"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "store:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/entropiaorme-backend",
          "sidecar": true,
          "args": []
        }
      ]
    }
  ]
}
