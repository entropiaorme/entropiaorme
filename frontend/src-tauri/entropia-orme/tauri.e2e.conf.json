{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "app": {
    "windows": [
      {
        "title": "EntropiaOrme",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false
      },
      {
        "label": "overlay",
        "title": "EntropiaOrme Overlay",
        "url": "/overlay",
        "width": 840,
        "height": 72,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "scan-overlay",
        "title": "EntropiaOrme Scan",
        "url": "/scan-overlay",
        "width": 320,
        "height": 220,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://entropiaorme.com; img-src 'self' data: http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'"
    }
  }
}
